<html>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>Payment Confirmation</title>
		<style>
			/* [Copy the same CSS from job-assigned.hbs for consistency] */
			/* Only changing specific styles below */

			body {
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				background-color: #f4f6f8;
				color: #334155;
			}
			.email-content {
				max-width: 600px;
				margin: 0 auto;
				background-color: #ffffff;
				border-radius: 8px;
				overflow: hidden;
			}
			.email-header {
				background-color: #ffffff;
				padding: 30px;
				text-align: center;
				border-bottom: 1px solid #e2e8f0;
			}
			.email-body {
				padding: 40px;
			}
			.job-card {
				background-color: #f0fdf4; /* Light Green Bg */
				border: 1px solid #bbf7d0;
				border-radius: 6px;
				padding: 20px;
				margin: 25px 0;
			}

			.label {
				font-size: 12px;
				text-transform: uppercase;
				color: #64748b;
				font-weight: 600;
				display: block;
				margin-bottom: 4px;
			}
			.value {
				font-size: 16px;
				font-weight: 500;
				color: #1e293b;
			}
			.amount-value {
				font-size: 20px;
				font-weight: 700;
				color: #15803d; /* Green Text */
			}

			.btn {
				display: inline-block;
				background-color: #15803d; /* Green Button */
				color: #ffffff;
				padding: 12px 32px;
				border-radius: 6px;
				text-decoration: none;
				font-weight: 600;
			}
			.email-footer {
				background-color: #f1f5f9;
				padding: 30px;
				text-align: center;
				font-size: 12px;
				color: #94a3b8;
			}
		</style>
	</head>
	<body>
		<div
			class='email-wrapper'
			style='padding: 40px 0; background-color: #f4f6f8;'
		>
			<table
				class='email-content'
				width='100%'
				cellpadding='0'
				cellspacing='0'
			>
				<tr>
					<td class='email-header'>
						<img
							src='{{logoUrl}}'
							alt='Cadsquad'
							style='height: 40px;'
						/>
					</td>
				</tr>
				<tr>
					<td class='email-body'>
						<h1
							style='font-size: 24px; color: #0f172a; margin-top: 0;'
						>Payment Received 💰</h1>
						<p>Hi <strong>{{recipientName}}</strong>,</p>
						<p>Great news! A payment has been recorded for the
							following job.</p>

						<div class='job-card'>
							<table width='100%'>
								<tr>
									<td style='padding-bottom: 15px;'>
										<span class='label'>Job Number</span>
										<div class='value'>{{jobNo}}</div>
									</td>
								</tr>
								<tr>
									<td style='padding-bottom: 15px;'>
										<span class='label'>Project</span>
										<div class='value'>{{jobTitle}}</div>
									</td>
								</tr>
								<tr>
									<td style='padding-bottom: 15px;'>
										<span class='label'>Amount Paid</span>
										<div
											class='amount-value'
										>{{amountFormatted}}</div>
									</td>
								</tr>
								<tr>
									<td>
										<span class='label'>Payment Date</span>
										<div class='value'>{{paidDate}}</div>
									</td>
								</tr>
							</table>
						</div>

						<div style='text-align: center; margin-top: 30px;'>
							<a href='{{jobLink}}' class='btn'>View Job Details</a>
						</div>
					</td>
				</tr>
				<tr>
					<td class='email-footer'>
						<p>&copy;
							{{currentYear}}
							Cadsquad. All rights reserved.</p>
					</td>
				</tr>
			</table>
		</div>
	</body>
</html>