<html>
    <head>
        <meta name='viewport' content='width=device-width, initial-scale=1.0' />
        <meta http-equiv='Content-Type' content='text/html; charset=UTF-8' />
        <title>Reset Your Password</title>
        <style>
            /* Base styles */
            body {
                background-color: #f6f6f6;
                font-family: sans-serif;
                -webkit-font-smoothing: antialiased;
                font-size: 14px;
                line-height: 1.4;
                margin: 0;
                padding: 0;
                -ms-text-size-adjust: 100%;
                -webkit-text-size-adjust: 100%;
            }

            /* Container */
            .container {
                display: block;
                margin: 0 auto !important;
                max-width: 580px;
                padding: 10px;
                width: 580px;
            }

            /* Card (White Box) */
            .content {
                box-sizing: border-box;
                display: block;
                margin: 0 auto;
                max-width: 580px;
                padding: 10px;
                background: #ffffff;
                border-radius: 8px;
                border: 1px solid #e9e9e9;
            }

            /* Typography */
            h1 {
                color: #333333;
                font-size: 24px;
                font-weight: 700;
                margin: 0;
                margin-bottom: 20px;
                text-align: center;
            }
            p,
            ul,
            ol {
                font-family: sans-serif;
                font-size: 14px;
                font-weight: normal;
                margin: 0;
                margin-bottom: 15px;
                color: #555555;
            }

            /* Button */
            .btn {
                box-sizing: border-box;
                width: 100%;
                margin-bottom: 20px;
            }
            .btn table {
                width: 100%;
            }
            .btn-primary td {
                background-color: #000000; /* Primary Color */
                border-radius: 5px;
                text-align: center;
            }
            .btn-primary a {
                background-color: #000000;
                border: solid 1px #000000;
                border-radius: 5px;
                box-sizing: border-box;
                color: #ffffff;
                cursor: pointer;
                display: inline-block;
                font-size: 14px;
                font-weight: bold;
                margin: 0;
                padding: 12px 25px;
                text-decoration: none;
                text-transform: capitalize;
                width: 100%;
            }

            /* Footer */
            .footer {
                clear: both;
                margin-top: 10px;
                text-align: center;
                width: 100%;
            }
            .footer td,
            .footer p,
            .footer span,
            .footer a {
                color: #999999;
                font-size: 12px;
                text-align: center;
            }

            /* Fallback Link */
            .fallback-link {
                font-size: 12px;
                color: #999999;
                word-break: break-all;
            }
        </style>
    </head>
    <body>
        <table
            role='presentation'
            border='0'
            cellpadding='0'
            cellspacing='0'
            class='body'
        >
            <tr>
                <td>&nbsp;</td>
                <td class='container'>
                    <div class='content'>
                        <table role='presentation' class='main'>
                            <tr>
                                <td style='padding: 20px;'>
                                    <table
                                        role='presentation'
                                        border='0'
                                        cellpadding='0'
                                        cellspacing='0'
                                    >
                                        <tr>
                                            <td>
                                                <h1>Reset Your Password</h1>

                                                <p>Hi {{name}},</p>

                                                <p>You recently requested to
                                                    reset your password for your
                                                    account. Use the button
                                                    below to reset it.
                                                    <strong>This password reset
                                                        link is only valid for
                                                        the next 15 minutes.</strong></p>

                                                <table
                                                    role='presentation'
                                                    border='0'
                                                    cellpadding='0'
                                                    cellspacing='0'
                                                    class='btn btn-primary'
                                                >
                                                    <tbody>
                                                        <tr>
                                                            <td align='center'>
                                                                <table
                                                                    role='presentation'
                                                                    border='0'
                                                                    cellpadding='0'
                                                                    cellspacing='0'
                                                                >
                                                                    <tbody>
                                                                        <tr>
                                                                            <td>
                                                                                <a
                                                                                    href='{{link}}'
                                                                                    target='_blank'
                                                                                >Reset
                                                                                    Password</a>
                                                                            </td>
                                                                        </tr>
                                                                    </tbody>
                                                                </table>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>

                                                <p>If you did not request a
                                                    password reset, please
                                                    ignore this email or contact
                                                    support if you have
                                                    questions.</p>

                                                <p>Thanks,<br />The Team</p>

                                                <hr
                                                    style='border: 0; border-top: 1px solid #eee; margin: 20px 0;'
                                                />
                                                <p
                                                    style='font-size: 12px; color: #999;'
                                                >Trouble clicking the button?
                                                    Copy and paste the URL below
                                                    into your web browser:</p>
                                                <p class='fallback-link'><a
                                                        href='{{link}}'
                                                        style='color: #666;'
                                                    >{{link}}</a></p>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>
                        <div class='footer'>
                            <table
                                role='presentation'
                                border='0'
                                cellpadding='0'
                                cellspacing='0'
                            >
                                <tr>
                                    <td class='content-block'>
                                        <span class='apple-link'>Your Company
                                            Name, 123 Street Address, City</span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </td>
                <td>&nbsp;</td>
            </tr>
        </table>
    </body>
</html>