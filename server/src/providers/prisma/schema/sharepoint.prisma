model SharepointItem {
    id              String  @id @default(uuid())
    itemId          String
    displayName     String?
    isFolder        Boolean @default(false)
    size            Int?
    webUrl          String?
    createdDateTime String?
    createdBy       String?
    jobs            Job[]

    publicWebUrl String?
    isAnonymous  Boolean? @default(false)

    syncStatus SharepointSyncStatus @default(FAILED)

    @@unique([itemId, id])
}

enum SharepointSyncStatus {
    FAILED
    SUCCESS
    SYNCING
}
