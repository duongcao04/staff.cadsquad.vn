// --- ENUMS CHO TÀI CHÍNH ---
enum TransactionType {
    INCOME // Tiền từ Client nạp vào cho Job
    PAYOUT // Tiền hệ thống chi trả cho Staff (từ JobAssignment)
    REFUND // Hoàn tiền nếu có sự cố
}

enum TransactionStatus {
    PENDING // Đang chờ xác nhận (Ví dụ: Staff tạo yêu cầu thanh toán)
    COMPLETED // Đã xong (Kế toán đã chuyển khoản/nhận tiền)
    FAILED // Giao dịch lỗi
    CANCELLED // Hủy giao dịch
}

// --- MODEL TRANSACTION CHÍNH ---
model Transaction {
    id       String            @id @default(uuid())
    amount   Float // Số tiền giao dịch
    currency String            @default("VND")
    type     TransactionType
    status   TransactionStatus @default(COMPLETED)

    // Thông tin đối soát thực tế
    referenceNo String? @unique // Mã giao dịch ngân hàng / Số hóa đơn
    note        String? // Nội dung chuyển khoản hoặc ghi chú thêm
    evidenceUrl String? // Link ảnh chụp bill chuyển khoản thành công

    // Quan hệ với Job (Giao dịch luôn thuộc về 1 Job)
    jobId String
    job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

    // Nguồn thu (Nếu type là INCOME)
    clientId String?
    client   Client? @relation(fields: [clientId], references: [id])

    // Đích chi (Nếu type là PAYOUT - Trả cho ai trong Job đó)
    assignmentId String?
    assignment   JobAssignment? @relation(fields: [assignmentId], references: [id])

    // Cổng thanh toán (Bank, MoMo, Crypto...)
    paymentChannelId String?
    paymentChannel   PaymentChannel? @relation(fields: [paymentChannelId], references: [id])

    // Người thực hiện/xác nhận giao dịch (Admin/Accounting)
    createdById String
    createdBy   User   @relation(fields: [createdById], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([jobId])
    @@index([type])
    @@index([status])
    @@index([createdAt])
}
