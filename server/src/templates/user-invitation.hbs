<html>
    <head>
        <meta charset='utf-8' />
        <style>
            .container {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                max-width: 600px;
                margin: 0 auto;
                border: 1px solid #e0e0e0;
                border-radius: 8px;
                overflow: hidden;
            }
            .header {
                background-color: #0070f3;
                color: white;
                padding: 24px;
                text-align: center;
            }
            .content {
                padding: 32px;
                line-height: 1.6;
                color: #333;
            }
            .cred-box {
                background-color: #f8f9fa;
                border: 1px dashed #0070f3;
                padding: 20px;
                border-radius: 8px;
                margin: 24px 0;
            }
            .button {
                display: inline-block;
                padding: 12px 24px;
                background-color: #0070f3;
                color: white !important;
                text-decoration: none;
                border-radius: 6px;
                font-weight: bold;
                margin-top: 16px;
            }
            .footer {
                background-color: #f4f4f4;
                color: #666;
                padding: 16px;
                text-align: center;
                font-size: 12px;
            }
        </style>
    </head>
    <body>
        <div class='container'>
            <div class='header'>
                <h1>Welcome to CAD SQUAD</h1>
            </div>
            <div class='content'>
                <p>Hi <strong>{{displayName}}</strong>,</p>
                <p>Your account has been successfully created. You can now
                    access the CAD SQUAD management system using the credentials
                    below:</p>

                <div class='cred-box'>
                    <p style='margin: 0;'><strong>Email:</strong> {{email}}</p>
                    <p style='margin: 8px 0 0 0;'><strong>Temporary Password:</strong>
                        <code style='color: #d63384;'>{{password}}</code></p>
                </div>

                <p>For security reasons, we highly recommend changing your
                    password after your first login.</p>

                <center>
                    <a href='{{loginUrl}}' class='button'>Login to Your Account</a>
                </center>
            </div>
            <div class='footer'>
                <p>&copy; 2026
                    <a href='https://www.cadsquad.vn'>CADSQUAD System</a>. All
                    rights reserved.<br />This is an automated email, please do
                    not reply.</p>
            </div>
        </div>
    </body>
</html>